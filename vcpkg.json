{
    "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
    "name": "photoedit",
    "version": "0.1.0",
    "description": "A flagship-level, Photoshop-class image editor (Windows first).",
    "homepage": "https://github.com/malloythedev/photoedit",
    "dependencies": [
        {
            "name": "qtbase",
            "default-features": false,
            "features": [
                "widgets",
                "gui",
                "png",
                "jpeg"
            ]
        },
        "littlecms",
        "libpng",
        "libjpeg-turbo",
        "tiff",
        "libwebp",
        "zlib",
        "libraw",
        "openexr"
    ],
    "builtin-baseline": "b322364c8a3b2b5f9e6f8e2d4a3c5b6d7e8f9a0b",
    "overrides": []
}
